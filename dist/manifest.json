{
  "name": "Tab Switcher",
  "description": "Chrome extension for tab switching in order of use",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/inject.js"]
    }
  ],
  "commands": {
    "gosu-switch": {
      "suggested_key": {
        "default": "Ctrl+Q",
        "mac": "Command+Q"
      },
      "description": "Run \"foo\" on the current page."
    },
    "gosu-switch2": {
      "suggested_key": {
        "default": "Ctrl+Y",
        "mac": "Command+Y"
      },
      "description": "Run \"goo\" on the current page."
    }
  },
  "permissions": ["scripting", "webRequest", "storage", "tabs", "favicon", "debugger"],
  "minimum_chrome_version": "127",
  "host_permissions": ["<all_urls>"]
}
