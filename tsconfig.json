{
  "compilerOptions": {
    "target": "es6",
    "module": "es2015",
    "moduleResolution": "node",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src/",
    "paths": {
      "@/*": ["*"]
    },
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    // "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react",
    "plugins": [
      { 
        "name": "typescript-plugin-css-modules",
        "options": {
          "namedExports": true
        }
      }
    ]
  },
  "include": [
    "src/**/*",
  ],
  "exclude": ["node_modules", "dist"]
}
